// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────

enum VehicleCondition {
  NEW
  USED
  CERTIFIED
}

enum VehicleStatus {
  AVAILABLE
  PENDING
  SOLD
}

enum BodyType {
  SEDAN
  SUV
  TRUCK
  COUPE
  CONVERTIBLE
  WAGON
  VAN
  HATCHBACK
}

enum FuelType {
  GASOLINE
  DIESEL
  ELECTRIC
  HYBRID
  PLUGIN_HYBRID
}

enum Transmission {
  AUTOMATIC
  MANUAL
  CVT
}

enum Drivetrain {
  FWD
  RWD
  AWD
  FOUR_WD
}

enum LeadType {
  INQUIRY
  TRADE_IN
  TEST_DRIVE
  RESERVATION
  FINANCING_PREQUAL
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
}

enum UserRole {
  CUSTOMER
  STAFF
  ADMIN
}

enum TestDriveStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

// ─── Models ─────────────────────────────────────────────────

model Vehicle {
  id              String           @id @default(cuid())
  slug            String           @unique
  vin             String?          @unique
  make            String
  model           String
  trim            String?
  year            Int
  price           Int
  mileage         Int
  bodyType        BodyType
  fuelType        FuelType
  transmission    Transmission
  drivetrain      Drivetrain
  exteriorColor   String
  interiorColor   String?
  condition       VehicleCondition
  status          VehicleStatus    @default(AVAILABLE)
  description     String?          @db.Text
  features        String[]
  images          String[]
  mpgCity         Int?
  mpgHighway      Int?
  engineInfo      String?
  horsepower      Int?
  daysOnLot       Int              @default(0)
  isNewArrival    Boolean          @default(true)
  isPriceDrop     Boolean          @default(false)
  previousPrice   Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  leads           Lead[]
  testDriveBookings TestDriveBooking[]
  favoritedBy     UserFavorite[]

  @@index([make, model])
  @@index([bodyType])
  @@index([price])
  @@index([year])
  @@index([status])
  @@index([condition])
}

model Lead {
  id              String     @id @default(cuid())
  type            LeadType
  vehicleId       String?
  vehicle         Vehicle?   @relation(fields: [vehicleId], references: [id])
  customerName    String
  email           String
  phone           String?
  message         String?    @db.Text
  preferredContact String?
  status          LeadStatus @default(NEW)
  assignedStaffId String?
  assignedStaff   User?      @relation("AssignedLeads", fields: [assignedStaffId], references: [id])
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  tradeInSubmission TradeInSubmission?
  testDriveBooking  TestDriveBooking?

  @@index([type])
  @@index([status])
  @@index([vehicleId])
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole   @default(CUSTOMER)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  favorites     UserFavorite[]
  assignedLeads Lead[]     @relation("AssignedLeads")
}

model UserFavorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, vehicleId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TradeInSubmission {
  id            String  @id @default(cuid())
  leadId        String  @unique
  lead          Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  vin           String?
  year          Int
  make          String
  model         String
  trim          String?
  mileage       Int
  condition     String
  features      String[]
  estimatedLow  Int?
  estimatedHigh Int?
  createdAt     DateTime @default(now())
}

model TestDriveBooking {
  id           String          @id @default(cuid())
  vehicleId    String
  vehicle      Vehicle         @relation(fields: [vehicleId], references: [id])
  leadId       String          @unique
  lead         Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  scheduledFor DateTime
  status       TestDriveStatus @default(PENDING)
  notes        String?         @db.Text
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([vehicleId])
  @@index([scheduledFor])
}

model DealershipSettings {
  id                  String  @id @default("default")
  name                String  @default("AutoLot")
  tagline             String  @default("Your Premier Destination for Quality Vehicles")
  phone               String  @default("(555) 123-4567")
  email               String  @default("info@autolot.com")
  address             String  @default("123 Auto Drive, Springfield, IL 62701")
  latitude            Float?
  longitude           Float?
  mondayHours         String  @default("9:00 AM - 8:00 PM")
  tuesdayHours        String  @default("9:00 AM - 8:00 PM")
  wednesdayHours      String  @default("9:00 AM - 8:00 PM")
  thursdayHours       String  @default("9:00 AM - 8:00 PM")
  fridayHours         String  @default("9:00 AM - 8:00 PM")
  saturdayHours       String  @default("9:00 AM - 6:00 PM")
  sundayHours         String  @default("Closed")
  financingDefaultAPR Float   @default(6.9)
  primaryColor        String  @default("#1e3a5f")
  accentColor         String  @default("#c17f3e")
}
